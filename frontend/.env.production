# Production build config (Cloudflare). Consumed by `vite build`.
# These are public endpoint URLs, not secrets.

# REST API (NestJS container behind the api-worker).
VITE_API_URL=https://api.berkdoc.com

# App notifications WebSocket (SmartExplorer) — shares the API container's main
# port at /app-ws, reachable through the api-worker.
VITE_APP_WS_URL=wss://api.berkdoc.com/app-ws

# tldraw realtime board-sync WebSocket (Durable Object sync worker).
VITE_WS_URL=wss://berkdoc-sync.kamal-aldin-94.workers.dev

# tldraw license key (see tldraw.dev/installation#License).
VITE_TLDRAW_LICENSE_KEY=tldraw-2026-07-01/WyJSOXNtNHluSiIsWyIqIl0sMTYsIjIwMjYtMDctMDEiXQ.g+5Oe9TlSnrkfBuloJsFFDiSQ0xCYXxh0sxsYp/GqFPESbFuCUE5Wqt+Ednp7x+Enme3JriWNMNz6KbVzQnmXA
