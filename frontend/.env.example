# Frontend environment configuration.
# Copy to `.env` and adjust per environment. All values have local-dev defaults,
# so an empty/missing .env works for local development.

# REST API base URL.
VITE_API_URL=http://localhost:3000

# App notifications WebSocket (SmartExplorer / scan stats).
VITE_APP_WS_URL=ws://localhost:3002

# tldraw realtime board-sync WebSocket.
# Local dev: the NestJS sync gateway on :3001 (default).
# Cloud: the Cloudflare Durable Object sync worker, e.g. wss://sync.berkdoc.com
VITE_WS_URL=ws://localhost:3001
