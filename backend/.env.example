# Database Configuration
# Driver selection: leave unset (or "bun-sqlite") for local SQLite development.
# Set DB_DRIVER=d1 (or provide the CLOUDFLARE_* vars below) to use Cloudflare D1.
DB_DRIVER=
# Local bun:sqlite database file path (used when DB_DRIVER is not d1)
DATABASE_PATH=./data/berkdoc.db
# Directory containing the .sql migration files (defaults to ./migrations)
DB_MIGRATIONS_DIR=./migrations
# Cloudflare D1 (only required when DB_DRIVER=d1)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_API_TOKEN=

# Blob/Avatar Storage Configuration
# Driver selection: leave unset (or "database") to store avatar blobs in the
# SQLite/D1 database (zero-config local default). Set BLOB_DRIVER=r2 for
# Cloudflare R2, or BLOB_DRIVER=s3 for any S3-compatible store (AWS S3, MinIO).
BLOB_DRIVER=
# Cloudflare R2 (only required when BLOB_DRIVER=r2)
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Endpoint defaults to https://<CLOUDFLARE_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_REGION=auto
# Optional object key prefix (defaults to "avatars/")
R2_PREFIX=
# Generic S3-compatible store (only required when BLOB_DRIVER=s3)
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_PREFIX=

# Event Bus / Async Pipeline Configuration
# Driver selection: leave unset (or "in-process") to dispatch domain events via
# the in-process EventEmitter (zero-config local default). Set
# EVENT_BUS=cloudflare-queue to publish events to a Cloudflare Queue and consume
# them via the HTTP-pull consumer (reuses CLOUDFLARE_ACCOUNT_ID/_API_TOKEN).
EVENT_BUS=
# Cloudflare Queue id (only required when EVENT_BUS=cloudflare-queue)
CLOUDFLARE_QUEUE_ID=
# Set to "false" to publish to the queue but let a separate consumer Worker
# process messages instead of this instance (defaults to true).
EVENT_BUS_CONSUMER=
# Consumer tuning (optional)
EVENT_BUS_POLL_INTERVAL_MS=1000
EVENT_BUS_BATCH_SIZE=10
EVENT_BUS_VISIBILITY_TIMEOUT_MS=30000

# JWT Configuration
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRATION=24h

# Embedding Provider Configuration
# Provider selection: leave unset (or "minilm"/"local") to use the in-process
# MiniLM model (all-MiniLM-L6-v2, 384-dim; zero-config local/offline default).
# Set EMBEDDING_PROVIDER=workers-ai to embed via Cloudflare Workers AI (BGE),
# reusing CLOUDFLARE_ACCOUNT_ID / CLOUDFLARE_API_TOKEN.
EMBEDDING_PROVIDER=
# Workers AI model (only used when EMBEDDING_PROVIDER=workers-ai). Known models:
#   @cf/baai/bge-small-en-v1.5 (384), @cf/baai/bge-base-en-v1.5 (768, default),
#   @cf/baai/bge-large-en-v1.5 (1024)
WORKERS_AI_EMBEDDING_MODEL=
# Override the output dimension if using a model not in the table above.
WORKERS_AI_EMBEDDING_DIMENSION=

# Weaviate Configuration
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_SCHEME=http

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Frontend URL (for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:5173


######### START LLM SERVICE CONFIGURATION #########
# LLM configuration 

### (`ollama` should be default)
LLM_PROVIDER=ollama

### ollama configuration is ignored if LLM_PROVIDER is not ollama
OLLAMA_BASE_URL=
OLLAMA_MODEL=gemma3:12b

### Gemini configuraion is ignored if LLM_PROVIDER is not gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

### Jarvis configuration is ignored if LLM_PROVIDER is not jarvis
JARVIS_API_KEY=
JARVIS_DEPLOYMENT_ID=
JARVIS_MODEL=gemma3:12b

### Runpod configuation is ignored if LLM_PROVIDER is not Runpod
RUNPOD_ENDPOINT_ID=
RUNPOD_API_KEY=

######### END LLM SERVICE CONFIGURATION #########

# Server Port
PORT=3000
